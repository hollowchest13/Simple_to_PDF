    "confirm_delete": {
      "header": "Delete file?",
      "message": "Are you sure you want to delete this file?",
      "btn_yes": "Yes",
      "btn_no": "No"
    }
  },

  "notifications": {
    "info": {
      "__title__": "Information",

      "license_info": {
        "header": "License Terms",
        "message": "Full license text goes here...",
        "footer_text": "Copyright © {year} {app_name}. All rights reserved...",
        "btn": "I Agree"
      },

      "no_updates": {
        "header": "Software Update",
        "message": "You're all set! Version {version} is the latest available.",
        "btn": "Got it"
      },

      "empty_file_list": {
        "header": "No files!",
        "message": "The file list is already empty.",
        "btn": "OK"
      }
    },

    "success": {
      "__title__": "Success",

      "update_success": {
        "header": "Software Updated",
        "message": "Version {version} has been installed successfully.",
        "btn": "Great!"
      }
    },

    "warning": {
      "__title__": "Warning!",

      "no_file_to_merge": {
        "header": "No files to merge!",
        "message": "Please add files to the list before proceeding with the merge.",
        "btn": "OK"
      },

      "wrong_page_format": {
        "header": "Wrong page format!",
        "message": "Please use the correct format (e.g., 1-5, 8, 10-12).",
        "btn": "Got it"
      },

      "process_in_progress": {
        "header": "Process in Progress!",
        "message": "A background task is currently running.\n\nThe application will close automatically once the task is finished. Please wait.",
        "btn": "Wait"
      },

      "file_not_found": {
        "header": "Not Found",
        "message": "File {file_name} not found",
        "btn": "Got it"
      }
    },

    "error": {
      "__title__": "File Error",

      "file_read_error": {
        "header": "Read Failure",
        "message": "File {file_name} read error",
        "btn": "Got it"
      },

      "page_validation_error": {
        "header": "Page validation error",
        "message": "Fatal error, error description: {error}",
        "btn": "Close"
      },

      "page_extraction_error": {
        "header": "Page extraction error",
        "message": "Error during page extraction, error description: {error}",
        "btn": "Close"
      },

      "update_error": {
        "header": "Update Error",
        "message": "Unable to check for updates:\n{error}",
        "btn": "Close"
      }
    }
  },

  "status": {
    "merge": {
      "done": "Merged: {success}; Failed: {failed}\nMerged PDF saved to:\n{path}",
      "error": "Error: Could not merge file: \n{path}\n\nReason: {error}"
    },
    "extract": {
      "done": "Extraction completed successfully!\nSaved to:\n{path}",
      "error": "Error: Could not extract page number: \n{number}\n\nReason: {error}"
    },
    "convert": {
      "done": "Converted: {success}; Failed: {failed}",
      "error": "Error: Could not convert file \n{path}\n\nReason: {error}"
    },
    "common": {
      "ready": "Ready"
    },
    "processing_page": "Processing page ({current}/{total})..."
 },
 "progress": {
    "stage": {
      "processing": "Processing",
      "extracting":"Extracting",
      "converting": "Converting",
      "merging": "Merging"
    },
    "indeterminate": "{stage} documents...",
    "detailed": "{stage}: {filename} ({current}/{total}) — {percent:.1f}%"
  }
}